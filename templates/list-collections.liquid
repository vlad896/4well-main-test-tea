{% comment %}
    The contents of the lists-collections.liquid template can be found in /sections/lists-collections-template.liquid
{% endcomment %}

{% render 'breadcrumb', breadcrumb_top: true %}


<div class="page-collectionList">
	<div class="container">
    	{% section 'collections-template' %}
    </div>
    {% section 'collections-custom-block' %}
    <div class="container">
    	{% section 'collections-products' %}
    </div>
    {% section 'collections-custom-block-2' %}
</div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": ["CollectionPage"],
  "@id": "{{ canonical_url }}#webpage",
  "url": {{ canonical_url | json }},
  "name": {{ page_title | json }},
  "isPartOf": {
    "@id": "{{ shop.url }}#website"
  },
  "breadcrumb": {
    "@id": "{{ canonical_url }}#breadcrumb"
  },
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": [
      {%- for collection in collections -%}
      {
        "@type": "ListItem",
        "position": {{ forloop.index }},
        "url": {{ collection.url | prepend: shop.url | json }},
        "name": {{ collection.title | json }}
      }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  }
}
</script>
