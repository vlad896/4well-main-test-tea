<!-- /snippets/social-meta-tags.liquid -->
{%- assign og_title = page_title -%}
{%- assign og_url = canonical_url -%}
{%- assign og_type = 'website' -%}
{%- assign og_description = page_description | default: shop.description | default: shop.name -%}
{%- assign og_image_url = '' -%}
{% if settings.share_image %}
    {%- assign og_image_url = settings.share_image | image_url: width: 1200, height: 1200 | prepend: 'https:' -%}
    {%- capture og_image_tags -%}<meta property="og:image" content="{{ og_image_url }}"><meta property="og:image:secure_url" content="{{ og_image_url }}">{%- endcapture -%}
{% endif %}

{% comment %} Template specific overides {% endcomment %}
{% if request.page_type == 'product' %}
    {%- assign og_title = product.title | strip_html -%}
    {%- assign og_type = 'product' -%}
    {% if product.images.size > 0 %}
        {%- assign og_image_url = product.featured_image.src | image_url: width: 1200, height: 1200 | prepend: 'https:' -%}
        {%- capture og_image_tags -%}{% for image in product.images limit:3 -%}<meta property="og:image" content="https:{{ image.src | image_url: width: 1200, height: 1200 }}"><meta property="og:image:secure_url" content="https:{{ image.src | image_url: width: 1200, height: 1200 }}">{% endfor -%}{% endcapture -%}
    {% endif %}

{% elsif request.page_type == 'article' %}
    {%- assign og_title = article.title | strip_html -%}
    {%- assign og_type = 'article' -%}
    {%- assign og_description = article.excerpt_or_content | strip_html | truncate: 300 -%}
    {% if article.image %}
        {%- assign og_image_url = article.image | image_url: width: 1200, height: 1200 | prepend: 'https:' -%}
        {%- capture og_image_tags -%}<meta property="og:image" content="{{ og_image_url }}"><meta property="og:image:secure_url" content="{{ og_image_url }}">{%- endcapture -%}
    {% endif %}

{% elsif request.page_type == 'collection' %}
    {%- assign og_title = collection.title | strip_html -%}
    {%- assign og_type = 'website' -%}
    {% if collection.image %}
        {%- assign og_image_url = collection.image | image_url: width: 1200, height: 1200 | prepend: 'https:' -%}
        {%- capture og_image_tags -%}<meta property="og:image" content="{{ og_image_url }}"><meta property="og:image:secure_url" content="{{ og_image_url }}">{%- endcapture -%}
    {% endif %}

{% elsif request.page_type == 'password' %}
    {%- assign og_title = shop.name -%}
    {%- assign og_url = shop.url -%}
    {%- assign og_description = shop.description | default: shop.name -%}
{% endif %}

<meta property="og:site_name" content="{{ shop.name | escape }}">
<meta property="og:locale" content="{{ request.locale.iso_code | default: shop.locale | replace: '-', '_' }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | escape }}">
{% if og_image_url != blank %}
    <meta property="og:image:alt" content="{{ og_title | escape }}">
    <meta property="og:image:type" content="image/jpeg">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="1200">
{% endif %}
{% if request.page_type == 'product' %}
    <meta property="og:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
    <meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
    <meta property="product:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
    <meta property="product:price:currency" content="{{ cart.currency.iso_code }}">
    <meta property="product:availability" content="{% if product.available %}in stock{% else %}out of stock{% endif %}">
    <meta property="product:condition" content="new">
    {% if product.vendor != blank %}<meta property="product:brand" content="{{ product.vendor | escape }}">{% endif %}
    {% if product.selected_or_first_available_variant.sku != blank %}<meta property="product:retailer_item_id" content="{{ product.selected_or_first_available_variant.sku | escape }}">{% endif %}
{% endif %}
{% if request.page_type == 'article' %}
    <meta name="author" content="{{ article.author | escape }}">
    <meta property="article:published_time" content="{{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' }}">
    <meta property="article:modified_time" content="{{ article.updated_at | date: '%Y-%m-%dT%H:%M:%SZ' }}">
    {% if blog.title != blank %}<meta property="article:section" content="{{ blog.title | escape }}">{% endif %}
    {% for tag in article.tags limit: 5 %}<meta property="article:tag" content="{{ tag | escape }}">{% endfor %}
{% endif %}
{{ og_image_tags }}

{% unless settings.social_twitter_link == blank %}
    <meta name="twitter:site" content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}">
{% endunless %}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | escape }}">
{% if og_image_url != blank %}
    <meta name="twitter:image" content="{{ og_image_url }}">
    <meta name="twitter:image:alt" content="{{ og_title | escape }}">
{% endif %}
